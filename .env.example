# =============================================================================
# 151 Trading System - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret
APP_LOG_LEVEL=INFO

# --- Database (PostgreSQL + TimescaleDB) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading_system
POSTGRES_USER=trading
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Celery ---
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# --- Data Providers ---
# Yahoo Finance (no key needed)
YAHOO_FINANCE_ENABLED=true

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=
FRED_ENABLED=true

# FMP (Financial Modeling Prep)
FMP_API_KEY=
FMP_ENABLED=true

# Polygon.io
POLYGON_API_KEY=
POLYGON_ENABLED=true

# Reddit (for sentiment)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=151TradingSystem/0.1
REDDIT_ENABLED=true

# Trading Economics
TRADING_ECONOMICS_CLIENT_KEY=
TRADING_ECONOMICS_SECRET_KEY=
TRADING_ECONOMICS_ENABLED=true

# B3 / Anbima (Brazilian markets)
B3_ENABLED=true
ANBIMA_ENABLED=true

# Fiscal AI (bluefiscal)
FISCAL_AI_API_KEY=
FISCAL_AI_ENABLED=true

# --- Broker (Alpaca) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_MODE=true

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Observability ---
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin
